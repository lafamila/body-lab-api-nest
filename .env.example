# Runtime
NODE_ENV=development
PORT=3020
HOST=0.0.0.0
PUBLIC_BASE_URL=http://localhost:3020
LAN_BASE_URL=http://192.168.0.10:3020
PRODUCTION_BASE_URL=https://lab.lafamila.xyz

# PostgreSQL body_lab database
DATABASE_URL=postgres://lafamila@localhost:5432/body_lab
DATABASE_SSL=false

# Shared Redis for account-scoped sync notifications
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=body-lab

# auth-api-nest session login + JWT validation
AUTH_API_BASE_URL=http://localhost:3032
AUTH_ISSUER_URL=http://localhost:3032
AUTH_JWKS_URL=http://localhost:3032/oauth/jwks
AUTH_AUDIENCE=service:body-lab
AUTH_SERVICE_KEY=body-lab
AUTH_DENIED_PERMISSIONS=visitor

# body-lab API confidential OIDC client registered in auth-api-nest
BODY_LAB_OIDC_CLIENT_ID=body-lab-api
BODY_LAB_OIDC_CLIENT_SECRET=replace_with_body_lab_oidc_client_secret
BODY_LAB_OIDC_REDIRECT_URI=http://localhost:3020/session/oidc/callback
BODY_LAB_OIDC_LOGIN_TRANSACTION_TTL_SECONDS=300

# body-lab-owned login session
BODY_LAB_SESSION_COOKIE_NAME=body_lab_session
BODY_LAB_SESSION_MAX_AGE_SECONDS=2592000
BODY_LAB_LOCAL_TIME_ZONE=Asia/Seoul
